# Gorgon Eye local environment template.
# Copy to .env.local. Do not commit .env.local.

# Threat intelligence (Safe Browsing hash-prefix lookup, opt-in).
VITE_SAFE_BROWSING_API_KEY=
VITE_ENABLE_SAFE_BROWSING=false

# Local LLM explanations (opt-in; default off).
# When the Local LLM toggle is enabled in the popup AND a hardware-capable
# Chrome (WebGPU) is detected, the explanation layer uses this MLC model id.
# The default below was selected by the AEG-4-1 hardware PoC
# (TTFT 1077 ms, 35.6 tok/s on an M3 Pro / 18 GB / WebGPU). Swap it here
# if you re-benchmark on different hardware.
VITE_ENABLE_LLM=false
VITE_WEBLLM_MODEL_ID=SmolLM2-1.7B-Instruct-q4f32_1-MLC

# Visual brand inspection (consent-gated, opt-in; default off).
VITE_ENABLE_VISUAL_INSPECTION=false
