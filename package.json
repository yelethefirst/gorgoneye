{
  "name": "gorgon-eye",
  "version": "0.0.1",
  "private": true,
  "description": "Privacy-preserving phishing defense browser extension.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "build:landing": "vite build --config vite.config.landing.ts",
    "compile": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prebuild": "node scripts/copy-ort-runtime.mjs",
    "prebuild:firefox": "node scripts/copy-ort-runtime.mjs",
    "predev": "node scripts/copy-ort-runtime.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.84",
    "fast-levenshtein": "^3.0.0",
    "onnxruntime-web": "^1.26.0",
    "punycode": "^2.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tldts": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.0.287",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^22.10.5",
    "@types/punycode": "^2.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8",
    "wxt": "^0.19.27"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  }
}
